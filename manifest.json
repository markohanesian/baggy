{
  "name": "Baggy",
  "description": "A Google chrome extension to assist with filling forms.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "main.html",
    "default_icon": {
        "16": "icons/form-helper-icon16.png",
        "32": "icons/form-helper-icon32.png",
        "48": "icons/form-helper-icon48.png",
        "128": "icons/form-helper-icon128.png"
    }
  },
  "permissions": ["clipboardWrite", "storage"]
}